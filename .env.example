# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# VAPID (Web Push)
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# iPaymu
IPAYMU_VA=your-va
IPAYMU_API_KEY=your-api-key
IPAYMU_PRODUCTION=true

# Digiflazz
DIGIFLAZZ_USERNAME=your-username
DIGIFLAZZ_API_KEY=your-api-key

# Gmail (SMTP)
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password

# Sariroti
SARIROTI_ADMIN_EMAIL=admin@sariroti.com

# App
APP_URL=https://yourdomain.com

# Sentry (Error Monitoring — optional)
SENTRY_DSN=https://key@o1.ingest.us.sentry.io/project

# Fixie Proxy (optional)
FIXIE_URL=

# Groq AI (receipt verification — replaces Gemini)
GROQ_TEXT_MODEL=llama-3.3-70b-versatile
# Optional override; default is the production-enabled multimodal model.
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_API_KEY=your-groq-api-key (gsk_...)
